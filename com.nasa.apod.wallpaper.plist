<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.nasa.apod.wallpaper</string>

    <key>ProgramArguments</key>
    <array>
        <string>/FULL/PATH/TO/nasa_apod_daily.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>3</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/FULL/PATH/TO/.nasa_apod_wallpapers/launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/FULL/PATH/TO/.nasa_apod_wallpapers/launchd_error.log</string>
</dict>
</plist>
